 		set_defaults();
@@ -737,7 +737,7 @@ void test_start(void)
 			    /* Do the same test for each CPU */
 			    if (++cpu_sel >= act_cpus) 
 			    	{
-	            cpu_sel = 0;
+				cpu_sel = 0;
 			        next_test();
 			    	} else {
 			        continue;
