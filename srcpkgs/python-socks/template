# Template file for 'python-socks'
pkgname=python-socks
version=1.7.0
revision=1
wrksrc="PySocks-${version}"
build_style=python-module
hostmakedepends="python-setuptools python3-setuptools"
depends="python"
short_desc="SOCKS4, SOCKS5 or HTTP proxy client library (Python2)"
maintainer="RunningDroid <runningdroid@zoho.com>"
