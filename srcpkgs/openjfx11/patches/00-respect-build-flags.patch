Mostly based on a patch from Georgy Yakovlev <gyakovlev@gentoo.org>

diff --unified --recursive buildSrc/linux.gradle buildSrc/linux.gradle
--- buildSrc/linux.gradle	2018-08-28 22:00:45.000000000 -0400
+++ buildSrc/linux.gradle	2019-12-31 01:42:53.197373346 -0500
@@ -43,7 +43,9 @@
 // A set of common parameters to use for both compiling and linking
 def commonFlags = [
         "-fno-strict-aliasing", "-fPIC", "-fno-omit-frame-pointer", // optimization flags
-        "-Wextra", "-Wall", "-Wformat-security", "-Wno-unused", "-Wno-parentheses", "-Werror=implicit-function-declaration"] // warning flags
+        "-Wextra", "-Wall", "-Wformat-security", "-Wno-unused", "-Wno-parentheses", "-Werror=implicit-function-declaration", "-Wno-error=cast-function-type"] // warning flags
+
+commonFlags.addAll(System.getenv("CFLAGS").trim().split(" "))
 
 if (!IS_64) {
     commonFlags += "-m32"
@@ -59,6 +61,8 @@
 def linkFlags = ["-static-libgcc", "-static-libstdc++", "-shared", commonFlags,
                  "-Wl,--gc-sections"].flatten()
 
+linkFlags.addAll(System.getenv("LDFLAGS").trim().split(" "))
+
 if (IS_DEBUG_NATIVE) {
     linkFlags += "-g"
 }
@@ -285,7 +289,7 @@
 LINUX.iio.compiler = compiler
 LINUX.iio.ccFlags = [ccFlags].flatten()
 LINUX.iio.linker = linker
-LINUX.iio.linkFlags = [linkFlags].flatten()
+LINUX.iio.linkFlags = [linkFlags, "-ljpeg"].flatten()
 LINUX.iio.lib = "javafx_iio"
 
 LINUX.prismES2 = [:]
